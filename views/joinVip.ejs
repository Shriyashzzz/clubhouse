<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join Vip</title>
    <link rel="stylesheet" href="authStyle.css" type=" text/css" />
  </head>
  <body>
    <div class="authContainer">
      <h3>Sign Up to be a member</h3>
      <form action="/join-vip" method="post">
        <label for="secret">Secret Code :</label>
        <input
          type="text"
          name="secret"
          id="secret"
          placeholder="Hint: Meow"
          required
        />
        <button>Sign Up</button>
      </form>
      <a href="/">Go Home</a>
    </div>
  </body>
</html>
