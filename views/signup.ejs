<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet"  href="authStyle.css" type=" text/css">
    <title>Sign Up</title>
  </head>
  <body>
    <div class = 'authContainer'> 
      <form action="/signup" , method="post">
        <label for="fname">First Name: </label>
        <input id = "fname" type="text"  name="fname" />
        <label for="lname">Last Name: </label>
        <input type="text" id = "lname" name="lname" />
        <label for="email">Email: </label>
        <input type="email" id = "email"   name="email" />
        <label for="username">Username: </label>
        <input type="text" id= 'username' name="username" />
        <label for="password">Password: </label>
        <input id= "password" type="password" name="password" />
        <label for="cpassword">Confirm Password: </label>
        <input type="password" id = "cpassword"  name="cpassword" />
        <label for="secret">Secret code to be a VIP(optional): </label>
        <input id="secret" type="text" placeholder="Hint: meow" name="secret" />
        <button type="submit">Sign up</button>
        <ul>
          <% if (locals.errors) { %>
              <% errors.map((error)=>{%>
                  <li><%= error.msg %></li>
            <%  }) %>
          <% } %>
        </ul>

      </form>
      <div>Already have a account?</div><a href="/login">Sign In
      </a>
    </div>
  </body>
</html>
